# Matrix-Claude Code Integration Environment Variables

# ===================
# Mode Selection
# ===================
# Options: "appservice" (default, recommended) or "bot" (fallback)
MATRIX_MODE=appservice

# ===================
# Matrix Configuration
# ===================
# Required: Your Matrix homeserver URL
MATRIX_HOMESERVER=https://matrix.example.com

# Bot mode only: Matrix user ID and access token
MATRIX_USER_ID=@claude-bot:matrix.example.com
MATRIX_ACCESS_TOKEN=your_access_token_here
MATRIX_DEVICE_ID=

# ===================
# Application Service Configuration
# ===================
# Unique identifier for this application service
AS_ID=claude-code-bridge

# Path to the registration YAML file (generated by --generate-registration)
AS_REGISTRATION_PATH=/path/to/registration.yaml

# Address to listen for homeserver callbacks
AS_LISTEN_ADDRESS=:8080

# URL the homeserver uses to reach this application service
AS_PUBLIC_URL=http://your-server:8080

# Tokens from the registration file (if not using registration_path)
AS_HS_TOKEN=
AS_TOKEN=

# Bot user configuration
AS_SENDER_LOCALPART=claude-bot
AS_HOMESERVER_DOMAIN=matrix.example.com

# ===================
# Claude Code Configuration
# ===================
# Working directory for Claude Code operations
CLAUDE_CODE_WORKING_DIR=/home/user/projects

# Model to use (optional, defaults to claude-sonnet-4-20250514)
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-3-5-20241022
CLAUDE_CODE_MODEL=claude-sonnet-4-20250514

# Optional system prompt prefix
CLAUDE_CODE_SYSTEM_PROMPT=

# Permission mode: "default", "plan", or "auto-approve"
CLAUDE_CODE_PERMISSION_MODE=default

# ===================
# Channel Configuration
# ===================
# Channel name shown in Claude Code (default: "matrix")
CHANNEL_NAME=matrix

# Run as MCP stdio server for Claude Code --channels flag
CHANNEL_STDIO_MODE=false

# HTTP port for standalone webhook receiver mode (0 = disabled)
CHANNEL_HTTP_PORT=0

# ===================
# Access Control
# ===================
# Whitelist of Matrix user IDs allowed to interact with the bot
# Can be JSON array or comma-separated list
# Use "*" to allow all users (not recommended for production)
MATRIX_WHITELIST=["@your-user:matrix.example.com"]
# Or: MATRIX_WHITELIST=@user1:matrix.org,@user2:matrix.org
